#!/usr/bin/env bash

set -euo pipefail

# Optional convenience mode:
#   AUTO_ENCRYPT_ENV=1 git commit
# This will attempt to regenerate .env.enc from .env before checks.
auto_encrypt_if_enabled() {
  if [[ "${AUTO_ENCRYPT_ENV:-0}" != "1" ]]; then
    return 0
  fi
  if [[ -f ".env" ]]; then
    if command -v sops >/dev/null 2>&1; then
      sops encrypt --input-type dotenv --output-type dotenv .env > .env.enc
      git add .env.enc
      echo "[pre-commit] Auto-regenerated .env.enc from .env"
    else
      echo "[pre-commit] AUTO_ENCRYPT_ENV=1 but sops is missing from PATH." >&2
      exit 1
    fi
  fi
}

is_plain_env_path() {
  local p="$1"
  case "${p}" in
    .env|*/.env)
      return 0
      ;;
    .env.*|*/.env.*)
      case "${p}" in
        *.enc|*.enc.*|*.example)
          return 1
          ;;
        *)
          return 0
          ;;
      esac
      ;;
    *)
      return 1
      ;;
  esac
}

main() {
  auto_encrypt_if_enabled

  local staged
  staged="$(git diff --cached --name-only --diff-filter=ACMR)"
  [[ -n "${staged}" ]] || exit 0

  local blocked=()
  while IFS= read -r path; do
    if is_plain_env_path "${path}"; then
      blocked+=("${path}")
    fi
  done <<< "${staged}"

  if [[ ${#blocked[@]} -gt 0 ]]; then
    echo "Commit blocked: plaintext .env file(s) are staged." >&2
    echo "Remove these from staging and keep only encrypted files (e.g. .env.enc):" >&2
    printf '  - %s\n' "${blocked[@]}" >&2
    echo "Tip: git restore --staged <file>" >&2
    exit 1
  fi
}

main "$@"

